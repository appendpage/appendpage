# Production env for append.page. Lives at /etc/appendpage/.env on the box,
# mode 600, owner appendpage:appendpage. NEVER commit a real one.

# --- Postgres ---
# In Docker Compose: db:5432. The host doesn't need to reach PG; only the app
# container does, via the compose network.
POSTGRES_PASSWORD=GENERATE_A_LONG_RANDOM_STRING_HERE
DATABASE_URL=postgres://appendpage:GENERATE_A_LONG_RANDOM_STRING_HERE@db:5432/appendpage

# --- Redis ---
REDIS_URL=redis://redis:6379

# --- Materializer output ---
PAGES_DIR=/var/lib/appendpage/pages

# --- OpenAI (Phase B) ---
# Resolved against /v1/models on 2026-04-20. Date-suffixed pin for reproducibility.
OPENAI_API_KEY=sk-...
OPENAI_PRIMARY_MODEL=gpt-5.4-mini-2026-03-17
OPENAI_FALLBACK_MODEL=gpt-5.4-nano-2026-03-17
OPENAI_DAILY_BUDGET_USD=50

# --- Cloudflare Turnstile (Phase B) ---
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --- GitHub OAuth (Phase B) ---
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_ADMIN_ALLOWLIST=da03

# --- Public-facing URL ---
PUBLIC_BASE_URL=https://append.page

# --- certbot registration email (used by infra/bootstrap.sh) ---
CERTBOT_EMAIL=da03@yuntiandeng.com

# --- IP-hash daily salt rotation seed (Phase B) ---
IP_HASH_SALT_SEED=GENERATE_A_LONG_RANDOM_STRING_HERE

# --- HuggingFace dataset push (Phase D) ---
HF_DATASET_REPO=appendpage/ledger
HF_TOKEN=
