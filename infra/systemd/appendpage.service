[Unit]
Description=append.page Next.js backend (bare Node, behind nginx)
Documentation=https://github.com/appendpage/appendpage
After=network-online.target docker.service
Wants=network-online.target

[Service]
Type=simple
User=appendpage
Group=appendpage
# WorkingDirectory is the REPO ROOT (not the standalone build output).
# This lets the markdown route handlers (/AGENTS.md, /privacy, etc.)
# resolve their files via process.cwd() + relative paths consistent with
# `npm run dev` from the server/ subdir. The handlers do:
#     join(process.cwd(), "..", "AGENTS.md")  // dev: cwd=server/  -> repo/AGENTS.md
# Set cwd to server/ so the same join works in prod from .next/standalone/.
WorkingDirectory=/var/lib/appendpage/compose/server

# Source the production env file (POSTGRES_PASSWORD, OPENAI_API_KEY, etc.)
EnvironmentFile=/etc/appendpage/.env

# Bind to a non-conflicting internal port; nginx proxies 443 -> 38080.
# 3000 and 3451 are taken by the existing tenants.
Environment=NODE_ENV=production
Environment=PORT=38080
Environment=HOSTNAME=127.0.0.1
Environment=NEXT_TELEMETRY_DISABLED=1
Environment=PAGES_DIR=/var/lib/appendpage/pages

# nvm-installed Node 20 lives under appendpage's home; make it explicit so
# systemd doesn't fall back to system node 12. server.js is in the standalone
# output dir; we run it from cwd=server/ (see WorkingDirectory above).
ExecStart=/var/lib/appendpage/.nvm/versions/node/v20.20.2/bin/node .next/standalone/server.js

Restart=on-failure
RestartSec=5s
StartLimitIntervalSec=60s
StartLimitBurst=10

# Light hardening (don't break the existing tenant pattern, just tighten ours).
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ReadWritePaths=/var/lib/appendpage
ProtectHome=read-only
ProtectKernelTunables=true
ProtectKernelModules=true
ProtectControlGroups=true
RestrictSUIDSGID=true

# Logs to journald; tail with: journalctl -u appendpage -f
StandardOutput=journal
StandardError=journal
SyslogIdentifier=appendpage

[Install]
WantedBy=multi-user.target
