# Local development env. Copy to .env and edit. NEVER commit .env.
# In production, /etc/appendpage/.env is the canonical location (mode 600,
# owner appendpage:appendpage).

# --- Postgres ---
# In Docker Compose: db:5432 (service name). For local non-Docker dev: 127.0.0.1:5432
DATABASE_URL=postgres://appendpage:appendpage@127.0.0.1:38432/appendpage

# --- Redis ---
REDIS_URL=redis://127.0.0.1:38379

# --- Where the materializer writes the public JSONL cache ---
PAGES_DIR=./var/pages

# --- OpenAI (Phase B onward) ---
# Resolve the actual model id against /v1/models from the prod box; we've
# verified that gpt-5.4-mini and gpt-5.4-nano exist (date-suffixed variants
# are the reproducible pin). Swap by changing only these two values.
OPENAI_API_KEY=
OPENAI_PRIMARY_MODEL=gpt-5.4-mini-2026-03-17
OPENAI_FALLBACK_MODEL=gpt-5.4-nano-2026-03-17
OPENAI_DAILY_BUDGET_USD=50

# --- Cloudflare Turnstile (Phase B onward) ---
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --- GitHub OAuth for the admin queue (Phase B onward) ---
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_ADMIN_ALLOWLIST=da03

# --- HuggingFace dataset push (Phase D) ---
HF_DATASET_REPO=appendpage/ledger
# Mount or set HF_TOKEN if not using `huggingface-cli login` on the host
HF_TOKEN=

# --- Public-facing URL (used in genesis seeds, AGENTS.md links, etc.) ---
PUBLIC_BASE_URL=http://localhost:3000

# --- Daily IP-hash salt rotation (Phase B) ---
# This is the seed for generating the daily rotating salts; never commit a
# real value. In prod it's generated once on bootstrap and stored in the
# sealed /etc/appendpage/.env.
IP_HASH_SALT_SEED=dev-only-not-secret-replace-me
